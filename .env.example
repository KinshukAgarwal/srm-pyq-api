# Supabase
# Option A: provide full URL
SUPABASE_URL="https://<project-id>.supabase.co"
# Option B: provide only project id (script builds URL)
PROJECT_ID="<project-id>"
# Service role key is recommended for ingestion/upsert
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Backward-compatible name used in this repo
API_KEY_SUPABASE="<service-role-key>"

# Cloudflare R2
R2_ACCOUNT_ID="<account-id>"
R2_ACCESS_KEY_ID="<access-key-id>"
R2_SECRET_ACCESS_KEY="<secret-access-key>"
R2_BUCKET="<bucket-name>"
R2_PUBLIC_BASE_URL="https://<public-domain-or-r2-dev-url>"
# Optional override (auto-computed when missing)
R2_ENDPOINT_URL="https://<account-id>.r2.cloudflarestorage.com"
